# ============================================================
# tiktok-api-backend env example
# ============================================================
# Quy tắc sinh secret:
#   ENCRYPTION_KEY: openssl rand -hex 32   (64 ký tự hex)
#   JWT_SECRET   : openssl rand -base64 48 (>=32 ký tự, không dùng default)
#   ADMIN_PASSWORD_HASH: dùng argon2 hash (an toàn hơn ADMIN_PASSWORD plaintext)
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
GLOBAL_PREFIX=api/v1

# --- MongoDB ---
# Mongo bật auth (root user/pass). MONGO_URI phải có credential + authSource=admin.
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change-me-strong-mongo-password
MONGO_URI=mongodb://root:change-me-strong-mongo-password@mongo:27017/tiktok_api?authSource=admin
MONGO_DB=tiktok_api

# --- Auth (single admin) ---
ADMIN_USERNAME=admin
# Khuyến cáo: dùng ADMIN_PASSWORD_HASH (argon2). Chỉ điền 1 trong 2 dưới đây.
ADMIN_PASSWORD=
# argon2 hash, sinh bằng: node -e "require('argon2').hash('your-pass').then(console.log)"
ADMIN_PASSWORD_HASH=

# JWT secret >=32 ký tự, KHÔNG dùng các default ('change-me', 'secret', 'replace-me'…)
JWT_SECRET=replace-with-a-long-random-string-32chars-or-more
JWT_EXPIRES_IN=12h

# --- Crypto ---
# Bắt buộc 64 ký tự hex (= 32 bytes). Dùng để mã hoá private_key của Service Account
# trước khi lưu DB (AES-256-GCM). Mất key này = mất toàn bộ SA đã upload.
ENCRYPTION_KEY=

# --- Network ---
# Whitelist origin cho CORS, ngăn cách bằng dấu phẩy. Để trống = chặn toàn bộ.
# Dùng "*" chỉ cho dev. Prod nên liệt kê domain cụ thể.
CORS_ORIGINS=

# Rate limit (request/phút)
RATE_LIMIT_GLOBAL=100
# Rate limit riêng cho /auth/login để chống brute-force
RATE_LIMIT_LOGIN=5

# --- TikTok / Puppeteer ---
# shopId/shopRegion KHÔNG đặt ở env — mỗi TikTok account lưu shop riêng trong DB
# (xem trang "TikTok Accounts" trong UI).
PUPPETEER_HEADLESS=true
SDK_DIR=/app/sdk
# Delay giữa các call profile (ms). 1000 = nhanh + an toàn. Hạ thấp hơn → rủi ro code_10000.
TIKTOK_DEFAULT_DELAY_MS=1000
# Default page size khi list creators không có query
CREATOR_LIST_DEFAULT_SIZE=12

# --- Frontend (web service) ---
# URL backend mà SPA gọi tới. Trên Coolify trỏ tới domain công khai của API.
# Dev local: để /api/v1 và đặt reverse proxy chuyển /api → api:3000.
VITE_API_URL=/api/v1
# Cổng bind cho web container (mặc định 8080 trong nginx.conf).
WEB_PORT=8080

# --- Google Sheets / Service Accounts ---
# KHÔNG còn dùng file SA nữa. Admin login → trang "Service Accounts" để upload JSON.
# Backend mã hoá private_key bằng ENCRYPTION_KEY và lưu vào collection service_accounts.
# Khi thêm 1 TikTok account, dùng GET /service-accounts/emails để hiển thị danh sách
# email SA — user phải share Google Sheet (Editor) cho các email đó trước khi save.

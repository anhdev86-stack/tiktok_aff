# Standalone deploy env — copy thành .env cạnh docker-compose.standalone.yml:
#   cp .env.standalone.example .env   (KHÔNG commit .env)
#
# Sinh secret (chạy trên VPS):
#   ENCRYPTION_KEY      : openssl rand -hex 32          (64 ký tự hex)
#   JWT_SECRET          : openssl rand -base64 48
#   MONGO_ROOT_PASSWORD : openssl rand -base64 24
#   ADMIN_PASSWORD_HASH : node -e "import('argon2').then(a=>a.hash('MAT_KHAU_MANH')).then(console.log)"

# --- Mongo (nội bộ, không mở port) ---
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=
MONGO_DB=tiktok_api

# --- Admin login ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

JWT_SECRET=
JWT_EXPIRES_IN=12h

# --- Bắt buộc, 64 hex ---
ENCRYPTION_KEY=

# FE gọi same-origin qua nginx proxy nên KHÔNG cần CORS. Để trống.
CORS_ORIGINS=

RATE_LIMIT_GLOBAL=100
RATE_LIMIT_LOGIN=5
TIKTOK_DEFAULT_DELAY_MS=1000

# Cổng host expose cho web (truy cập http://<IP_VPS>:WEB_PORT). Đổi nếu trùng.
WEB_PORT=8081
